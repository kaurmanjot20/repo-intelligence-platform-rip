{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV", "DATABASE_URL", "NEO4J_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
