# PostgreSQL
DATABASE_URL=postgresql://rip:rip@localhost:5432/rip

# Neo4j (bolt:// for driver, http:// for browser)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rippassword

# File storage for cloned repos and AST cache
DATA_DIR=./data/repositories

# API port (NestJS)
PORT=3001

# CORS — allow Next.js dev server
CORS_ORIGIN=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
